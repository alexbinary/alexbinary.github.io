case "$1" in
	open)
		open .
		code .
		clear
		git status
		;;
	start)
		open --background -a Docker
		while ! docker system info > /dev/null 2>&1; do sleep 1; done
		docker run --rm -it -v .:/app -v ../build:/build -w /app -p 4000:4000 -p 35729:35729 jekyll/minimal jekyll serve --livereload --drafts
		;;
	deploy)
        rm -r ../build/*
		docker run --rm -it -v .:/app -v ../build:/build -w /app jekyll/minimal jekyll build
		cd ../build
		git add .
		git commit -m "commit"
		git push
		;;
	newproject)
		mkdir en/projects/_new
		mkdir fr/projets/_new
		cp _templates/project.markdown en/projects/_new/index.markdown
		cp _templates/project.markdown fr/projets/_new/index.markdown
		code en/projects/_new/index.markdown
		;;
	gif)
		ffmpeg -i $2 -vf "fps=15,scale=$3:-1:flags=lanczos,palettegen" palette.png
		ffmpeg -i $2 -i palette.png -filter_complex "fps=15,scale=$3:-1:flags=lanczos[x];[x][1:v]paletteuse" $2.gif
		rm palette.png
		;;
	video)
		ffmpeg -i $2 -an -c:v libx264 -crf 30 -preset slow -vf "fps=15,scale=1040:-2" -movflags +faststart $2.mp4
		;;
	photo)
		magick $2 -strip -interlace Plane -quality 75 $2
		;;
	*)
		echo "Usage: dev {open|start|deploy|newproject|gif|video|photo}"
		;;
esac